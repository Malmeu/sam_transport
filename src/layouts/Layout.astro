---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "SAM'S TRANSPORT - Votre partenaire de confiance pour le transport, le déménagement, le débarras et le nettoyage principalement en Île-de-France et dans toute la France." } = Astro.props;
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | SAM'S TRANSPORT</title>
    
    <!-- SEO Local -->
    <meta name="geo.region" content="FR-95" />
    <meta name="geo.placename" content="Vauréal" />
    <meta name="geo.position" content="49.0333;2.0333" />
    <meta name="ICBM" content="49.0333, 2.0333" />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="SAM'S TRANSPORT" />
    
    <!-- Schema.org JSON-LD LocalBusiness -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "SAM'S TRANSPORT",
        "image": "https://sams-transport.fr/logo_samTransport.png",
        "logo": "https://sams-transport.fr/logo_samTransport.png",
        "url": "https://sams-transport.fr",
        "telephone": "01 23 45 67 89",
        "email": "contact@sams-transport.fr",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "87 boulevard de l'Oise",
          "addressLocality": "Vauréal",
          "postalCode": "95490",
          "addressRegion": "Val-d'Oise",
          "addressCountry": "FR"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 49.0333,
          "longitude": 2.0333
        },
        "openingHoursSpecification": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": [
            "Monday",
            "Tuesday",
            "Wednesday",
            "Thursday",
            "Friday",
            "Saturday"
          ],
          "opens": "08:00",
          "closes": "19:00"
        },
        "priceRange": "$$"
      }
    </script>
	</head>
	<body>
		<slot />
	</body>
</html>
