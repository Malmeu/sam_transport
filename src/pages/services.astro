---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import SectionHeading from '../components/SectionHeading.astro';

const services = [
  {
    id: "demenagement",
    title: "Déménagement",
    text: "Nous organisons votre déménagement local ou régional depuis Vauréal et les communes voisines. Notre équipe prend en charge la protection du mobilier, la manutention, le chargement et le déchargement, avec une attention particulière pour les accès (escaliers, ascenseurs, couloirs étroits). Que vous quittiez un studio, un appartement, une maison ou de petits locaux professionnels, nous adaptons le véhicule, l’équipe et le niveau d’accompagnement : simple aide à la manutention ou prise en charge complète."
  },
  {
    id: "debarras",
    title: "Débarras",
    text: "Nous intervenons pour vider les logements (maison, appartement, cave, grenier) et les locaux professionnels, que ce soit après une vente, une succession, un départ en maison de retraite ou un changement de locataire. Nous trions, évacuons et orientons les objets vers les filières adaptées (recyclage, déchetterie, valorisation lorsque c’est possible), puis nous laissons les lieux rangés et débarrassés."
  },
  {
    id: "nettoyage",
    title: "Nettoyage après intervention",
    text: "Après un déménagement ou un débarras, il reste souvent poussières, traces et petits déchets. Nous proposons un service de nettoyage ciblé pour rendre les pièces propres et présentables avant état des lieux, remise des clés ou visite d’un futur acquéreur. L’intervention peut inclure le nettoyage des sols, des surfaces accessibles et l’évacuation des derniers résidus liés à la prestation."
  },
  {
    id: "objets-lourds",
    title: "Transport d’objets lourds et encombrants",
    text: "Certains objets demandent plus qu’un simple coup de main : grands meubles, électroménager, équipements lourds, matériel professionnel… Nous disposons de l’expérience et du matériel nécessaires pour transporter ces éléments en sécurité, depuis ou vers votre logement ou vos locaux. Nous étudions au préalable les accès (escaliers, ascenseur, largeur des portes) afin de prévoir la solution la plus adaptée et éviter tout dommage."
  },
  {
    id: "manutention",
    title: "Manutention et services sur mesure",
    text: "Vous avez besoin d’aide ponctuelle pour déplacer des meubles, réorganiser un local, monter ou démonter du mobilier ? Nous proposons des prestations de manutention sur mesure pour les particuliers, commerces, bureaux, hôtels ou petites structures. Nous intervenons sur rendez‑vous, pour quelques heures ou une demi‑journée, avec une équipe adaptée au volume de travail."
  }
];
---

<Layout title="Nos services de transport, déménagement et débarras | SAM'S TRANSPORT">
  <Header />
  
  <main>
    <section class="page-header section-padding">
      <div class="container animate-fade">
        <h1>Nos services de transport, déménagement, débarras et nettoyage</h1>
        <p class="intro-text">SAM’S TRANSPORT propose une gamme de services conçus pour couvrir toutes les situations du quotidien : déménagement, vide maison ou appartement, enlèvement d’encombrants, nettoyage après déménagement et transport d’objets lourds. Chaque service est modulable pour coller au plus près à votre demande.</p>
      </div>
    </section>

    {services.map((service, index) => (
      <section id={service.id} class={`service-detail section-padding ${index % 2 !== 0 ? 'bg-alt' : ''}`}>
        <div class="container grid-2">
          <div class={index % 2 !== 0 ? 'order-2' : ''}>
            <SectionHeading title={service.title} />
            <p>{service.text}</p>
            <div class="service-actions">
              <a href="/devis" class="btn btn-primary">Demander un devis pour ce service</a>
            </div>
          </div>
          <div class="service-image-placeholder glass">
            {/* Image illustrative à ajouter ici */}
            <div class="placeholder-icon">🚚</div>
          </div>
        </div>
      </section>
    ))}

    <section class="cta-section section-padding">
      <div class="container centered-content">
        <SectionHeading title="Besoin d'un service sur mesure ?" centered={true} />
        <p>Vous ne savez pas exactement dans quelle catégorie se situe votre besoin ? Contactez‑nous : nous vous orientons vers la bonne solution et vous proposons un devis adapté.</p>
        <div class="cta-btns centered">
          <a href="/contact" class="btn btn-outline">Nous contacter</a>
          <a href="/devis" class="btn btn-primary">Demander mon devis</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .page-header {
    background: var(--gradient-primary);
    color: var(--white);
    padding-top: 150px;
    padding-bottom: 80px;
    text-align: center;
  }
  
  .page-header h1 {
    color: var(--white);
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: 1.5rem;
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .intro-text {
    font-size: 1.2rem;
    color: var(--text-light);
    max-width: 800px;
    margin: 0 auto;
    line-height: 1.8;
  }
  
  .grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  
  .order-2 {
    order: 2;
  }
  
  .service-detail p {
    font-size: 1.1rem;
    line-height: 1.8;
    margin-bottom: 2rem;
  }
  
  .service-image-placeholder {
    height: 400px;
    background: var(--bg-alt);
    border-radius: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 5rem;
    border: 1px solid rgba(0,0,0,0.05);
  }
  
  .bg-alt {
    background-color: var(--bg-alt);
  }
  
  .service-actions {
    margin-top: 2rem;
  }
  
  .centered-content {
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }
  
  .cta-btns {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-top: 2.5rem;
  }
  
  @media (max-width: 992px) {
    .grid-2 {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    
    .order-2 {
      order: 0;
    }
    
    .service-image-placeholder {
      height: 250px;
    }
  }
</style>
