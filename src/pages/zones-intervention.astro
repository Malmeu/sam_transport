---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import SectionHeading from '../components/SectionHeading.astro';
---

<Layout title="Nos zones d'intervention - Île-de-France et toute la France | SAM'S TRANSPORT">
  <Header />
  
  <main>
    <section class="page-header">
      <div class="container animate-fade">
        <h1>Nos zones d’intervention</h1>
        <p class="intro-text">SAM’S TRANSPORT est basée à Vauréal, au 87 boulevard de l’Oise. Nous intervenons principalement dans toute la région de l'Île-de-France, mais nous couvrons également l'ensemble du territoire national pour tous vos projets de déménagement et de transport de longue distance.</p>
      </div>
    </section>

    <section class="zones-detail section-padding">
      <div class="container grid-2">
        <div>
          <SectionHeading title="Île-de-France & France entière" subtitle="Couverture complète" />
          <p>Notre siège étant situé au cœur de l'Île-de-France à Vauréal (95), nous couvrons l'ensemble des départements franciliens pour des interventions rapides et planifiées. Pour vos déménagements de moyenne et longue distance, nous intervenons également dans toutes les régions de France.</p>
          
          <div class="cities-list">
            <span class="city-tag">Île-de-France</span>
            <a href="/zones-intervention/vaureal" class="city-tag">Val-d'Oise (95)</a>
            <a href="/zones-intervention/cergy" class="city-tag">Cergy</a>
            <a href="/zones-intervention/pontoise" class="city-tag">Pontoise</a>
            <span class="city-tag">Paris (75)</span>
            <span class="city-tag">Yvelines (78)</span>
            <span class="city-tag">Hauts-de-Seine (92)</span>
            <span class="city-tag">Seine-Saint-Denis (93)</span>
            <span class="city-tag">Val-de-Marne (94)</span>
            <span class="city-tag">Essonne (91)</span>
            <span class="city-tag">Seine-et-Marne (77)</span>
            <span class="city-tag active-tag">France entière</span>
          </div>
        </div>

        <!-- Carte Réelle et Animation des Régions -->
        <div class="map-container glass">
          <div class="map-controls">
            <button class="map-ctrl-btn active" id="btn-anim" data-mode="anim">Autoplay</button>
            <button class="map-ctrl-btn" id="btn-idf" data-mode="idf">Île-de-France</button>
            <button class="map-ctrl-btn" id="btn-france" data-mode="france">France entière</button>
          </div>
          <div class="map-viewport show-hq">
            <!-- Carte Réelle des Régions en Arrière-plan -->
            <img src="/carte-france-region - Grande.png" alt="Carte des régions de France" class="france-map-img" />
            
            <!-- Calque d'animation vectorielle (SVG) superposé -->
            <svg viewBox="0 0 375 418" class="vector-map-overlay">
              <defs>
                <radialGradient id="idf-grad" cx="50%" cy="50%" r="50%">
                  <stop offset="0%" stop-color="#BF6411" stop-opacity="0.85" />
                  <stop offset="100%" stop-color="#BF6411" stop-opacity="0" />
                </radialGradient>
                <radialGradient id="france-grad" cx="50%" cy="50%" r="50%">
                  <stop offset="0%" stop-color="#BF6411" stop-opacity="0.6" />
                  <stop offset="100%" stop-color="#BF6411" stop-opacity="0" />
                </radialGradient>
              </defs>

              <!-- Zones de couverture lumineuses -->
              <!-- Île-de-France (glow orange) -->
              <circle cx="195" cy="96" r="35" class="coverage-ring idf-ring" />
              <!-- France entière (glow étendu) -->
              <circle cx="195" cy="200" r="180" class="coverage-ring national-ring" />
              
              <!-- Lignes de trajets animées de la flotte partant d'Île-de-France (195, 96) -->
              <g class="region-connections">
                <line x1="195" y1="96" x2="214" y2="25" class="route-line" /> <!-- Nord-Pas-de-Calais -->
                <line x1="195" y1="96" x2="206" y2="63" class="route-line" /> <!-- Picardie -->
                <line x1="195" y1="96" x2="158" y2="54" class="route-line" /> <!-- Haute-Normandie -->
                <line x1="195" y1="96" x2="128" y2="84" class="route-line" /> <!-- Basse-Normandie -->
                <line x1="195" y1="96" x2="45" y2="113" class="route-line" /> <!-- Bretagne -->
                <line x1="195" y1="96" x2="105" y2="138" class="route-line" /> <!-- Pays de la Loire -->
                <line x1="195" y1="96" x2="180" y2="155" class="route-line" /> <!-- Centre -->
                <line x1="195" y1="96" x2="244" y2="163" class="route-line" /> <!-- Bourgogne -->
                <line x1="195" y1="96" x2="255" y2="109" class="route-line" /> <!-- Champagne-Ardenne -->
                <line x1="195" y1="96" x2="300" y2="100" class="route-line" /> <!-- Lorraine -->
                <line x1="195" y1="96" x2="341" y2="134" class="route-line" /> <!-- Alsace -->
                <line x1="195" y1="96" x2="293" y2="167" class="route-line" /> <!-- Franche-Comté -->
                <line x1="195" y1="96" x2="113" y2="213" class="route-line" /> <!-- Poitou-Charentes -->
                <line x1="195" y1="96" x2="173" y2="230" class="route-line" /> <!-- Limousin -->
                <line x1="195" y1="96" x2="214" y2="251" class="route-line" /> <!-- Auvergne -->
                <line x1="195" y1="96" x2="274" y2="242" class="route-line" /> <!-- Rhône-Alpes -->
                <line x1="195" y1="96" x2="101" y2="284" class="route-line" /> <!-- Aquitaine -->
                <line x1="195" y1="96" x2="154" y2="318" class="route-line" /> <!-- Midi-Pyrénées -->
                <line x1="195" y1="96" x2="218" y2="326" class="route-line" /> <!-- Languedoc-Roussillon -->
                <line x1="195" y1="96" x2="289" y2="314" class="route-line" /> <!-- PACA -->
                <line x1="195" y1="96" x2="349" y2="380" class="route-line" /> <!-- Corse -->
              </g>
              
              <!-- Nœuds de destinations et Siège social -->
              <g class="region-dots">
                <!-- Vauréal / Siège -->
                <circle cx="195" cy="96" r="6" class="city-dot hq-dot" />
                <circle cx="195" cy="96" r="12" class="city-dot hq-pulse" />
                
                <!-- Cercles régionaux -->
                <circle cx="214" cy="25" r="3.5" class="region-node" />
                <circle cx="206" cy="63" r="3.5" class="region-node" />
                <circle cx="158" cy="54" r="3.5" class="region-node" />
                <circle cx="128" cy="84" r="3.5" class="region-node" />
                <circle cx="45" cy="113" r="3.5" class="region-node" />
                <circle cx="105" cy="138" r="3.5" class="region-node" />
                <circle cx="180" cy="155" r="3.5" class="region-node" />
                <circle cx="244" cy="163" r="3.5" class="region-node" />
                <circle cx="255" cy="109" r="3.5" class="region-node" />
                <circle cx="300" cy="100" r="3.5" class="region-node" />
                <circle cx="341" cy="134" r="3.5" class="region-node" />
                <circle cx="293" cy="167" r="3.5" class="region-node" />
                <circle cx="113" cy="213" r="3.5" class="region-node" />
                <circle cx="173" cy="230" r="3.5" class="region-node" />
                <circle cx="214" cy="251" r="3.5" class="region-node" />
                <circle cx="274" cy="242" r="3.5" class="region-node" />
                <circle cx="101" cy="284" r="3.5" class="region-node" />
                <circle cx="154" cy="318" r="3.5" class="region-node" />
                <circle cx="218" cy="326" r="3.5" class="region-node" />
                <circle cx="289" cy="314" r="3.5" class="region-node" />
                <circle cx="349" cy="380" r="3.5" class="region-node" />
                
                <text x="210" y="93" class="map-label hq-label">Vauréal (Siège)</text>
              </g>
            </svg>
            <div class="map-status-overlay">
              <span class="status-badge" id="map-status">Initialisation...</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="zones-extra section-padding bg-alt">
      <div class="container">
        <div class="centered-content">
          <SectionHeading title="Île-de-France & France entière" subtitle="Rayon d'action élargi" centered={true} />
          <p>Grâce à notre infrastructure de transport routier robuste, nous organisons régulièrement des déménagements et des livraisons de fret depuis l'Île-de-France (Val-d'Oise, Paris, Yvelines...) vers toutes les autres régions françaises (Auvergne-Rhône-Alpes, PACA, Nouvelle-Aquitaine, Bretagne, etc.) et vice versa.</p>
        </div>
      </div>
    </section>

    <section class="zones-faq section-padding">
      <div class="container centered-content">
        <SectionHeading title="Vous ne voyez pas votre ville dans la liste ?" subtitle="Une question ?" centered={true} />
        <p>Même si votre commune n’est pas citée, nous pouvons intervenir. Que ce soit en Île-de-France ou partout ailleurs en France, le plus simple est de nous envoyer une demande de devis ou de nous appeler en précisant vos adresses de départ et d'arrivée. Nous vous répondrons rapidement.</p>
        <div class="cta-btns centered">
          <a href="tel:0123456789" class="btn btn-primary">Nous appeler : 01 23 45 67 89</a>
          <a href="/devis" class="btn btn-outline">Demander un devis</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .page-header {
    background: linear-gradient(rgba(18, 18, 18, 0.8), rgba(18, 18, 18, 0.8)), url('/images/zones_hero.png') no-repeat center center;
    background-size: cover;
    color: var(--white);
    padding-top: 150px;
    padding-bottom: 80px;
    text-align: center;
  }
  
  .page-header h1 {
    color: var(--white);
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: 1.5rem;
  }
  
  .intro-text {
    font-size: 1.2rem;
    color: var(--text-light);
    max-width: 800px;
    margin: 0 auto;
    line-height: 1.8;
  }
  
  .grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  
  .zones-detail p {
    font-size: 1.1rem;
    line-height: 1.8;
    margin-bottom: 2rem;
  }
  
  .cities-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 2rem;
  }
  
  .city-tag {
    padding: 0.5rem 1.2rem;
    background: var(--bg-alt);
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.9rem;
    border: 1px solid rgba(0,0,0,0.05);
    color: var(--primary);
    transition: var(--transition);
  }

  .city-tag:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .active-tag {
    background: var(--accent);
    color: var(--white);
    border-color: var(--accent);
  }
  
  /* Widget de Carte Animée sur la vraie image des régions */
  .map-container {
    background: #181818;
    border-radius: 30px;
    padding: 1.5rem;
    box-shadow: var(--shadow-lg);
    border: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    overflow: hidden;
  }
  
  .map-controls {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.05);
    padding: 0.4rem;
    border-radius: 50px;
    align-self: center;
    z-index: 5;
  }
  
  .map-ctrl-btn {
    padding: 0.5rem 1.2rem;
    background: transparent;
    border: none;
    color: var(--text-light);
    font-weight: 600;
    font-size: 0.85rem;
    font-family: 'Outfit', sans-serif;
    border-radius: 50px;
    cursor: pointer;
    transition: var(--transition);
  }
  
  .map-ctrl-btn:hover {
    color: var(--white);
  }
  
  .map-ctrl-btn.active {
    background: var(--accent);
    color: var(--white);
  }
  
  .map-viewport {
    position: relative;
    background: #111;
    border-radius: 20px;
    max-width: 420px;
    width: 100%;
    aspect-ratio: 375/418;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }
  
  .france-map-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.8;
    filter: brightness(0.65) contrast(1.15); /* Assombri pour faire ressortir les animations lumineuses */
    transition: var(--transition);
    z-index: 1;
  }
  
  .vector-map-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
    pointer-events: none;
  }
  
  /* City Dots & nodes */
  .city-dot {
    fill: #555555;
    stroke: #222;
    stroke-width: 1;
    transition: var(--transition);
  }
  
  .hq-dot {
    fill: var(--accent);
    stroke: var(--white);
    stroke-width: 1.5;
    filter: drop-shadow(0 0 5px var(--accent));
  }
  
  .hq-pulse {
    fill: var(--accent);
    opacity: 0.4;
    animation: hqPulseAnim 2s infinite;
    transform-origin: 195px 96px;
  }
  
  @keyframes hqPulseAnim {
    0% {
      r: 6px;
      opacity: 0.6;
    }
    100% {
      r: 20px;
      opacity: 0;
    }
  }

  .region-node {
    fill: #555555;
    stroke: #222;
    stroke-width: 1;
    opacity: 0;
    transition: all 0.6s ease;
  }
  
  .map-label {
    fill: #888888;
    font-size: 8px;
    font-family: 'Outfit', sans-serif;
    font-weight: 500;
    pointer-events: none;
    transition: var(--transition);
    opacity: 0;
  }
  
  .hq-label {
    fill: var(--white);
    font-weight: 700;
    font-size: 9px;
    opacity: 1;
  }
  
  /* Anneaux de couverture */
  .coverage-ring {
    fill: var(--accent);
    opacity: 0;
    transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }
  
  .idf-ring {
    opacity: 0;
    transform: scale(0.2);
    fill: url(#idf-grad);
    transform-origin: 195px 96px;
  }
  
  .national-ring {
    opacity: 0;
    transform: scale(0.2);
    fill: url(#france-grad);
    transform-origin: 195px 200px;
  }
  
  /* Lignes de trajets */
  .route-line {
    stroke: var(--accent);
    stroke-width: 1.5;
    stroke-dasharray: 6, 4;
    stroke-linecap: round;
    opacity: 0;
    transition: opacity 0.6s ease;
    animation: routePulse 1.5s infinite linear;
  }
  
  @keyframes routePulse {
    to {
      stroke-dashoffset: -20;
    }
  }
  
  /* États actifs */
  .map-viewport.show-idf .idf-ring {
    opacity: 0.45;
    transform: scale(1);
  }
  
  .map-viewport.show-france .national-ring {
    opacity: 0.38;
    transform: scale(1);
  }
  
  .map-viewport.show-france .idf-ring {
    opacity: 0.15;
    transform: scale(1);
  }
  
  .map-viewport.show-france .route-line {
    opacity: 0.8;
  }
  
  .map-viewport.show-france .region-node {
    fill: var(--accent);
    stroke: var(--white);
    opacity: 1;
    filter: drop-shadow(0 0 2px var(--accent));
  }
  
  /* Status overlay */
  .map-status-overlay {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    right: 1rem;
    pointer-events: none;
    display: flex;
    justify-content: center;
    z-index: 3;
  }
  
  .status-badge {
    background: rgba(18, 18, 18, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--white);
    padding: 0.5rem 1.2rem;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    backdrop-filter: blur(10px);
    box-shadow: var(--shadow-md);
    transition: var(--transition);
  }
  
  .bg-alt {
    background-color: var(--bg-alt);
  }
  
  .centered-content {
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }
  
  .cta-btns {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-top: 2.5rem;
  }
  
  @media (max-width: 992px) {
    .grid-2 {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>

<script>
  const btnAnim = document.getElementById('btn-anim');
  const btnIdf = document.getElementById('btn-idf');
  const btnFrance = document.getElementById('btn-france');
  const viewport = document.querySelector('.map-viewport');
  const statusText = document.getElementById('map-status');
  
  let currentMode = 'anim'; // anim, idf, france
  let autoplayInterval;
  let autoplayStep = 0;
  
  function setMode(mode) {
    currentMode = mode;
    
    // Mettre à jour l'état visuel des boutons
    [btnAnim, btnIdf, btnFrance].forEach(btn => btn.classList.remove('active'));
    if (mode === 'anim') btnAnim.classList.add('active');
    else if (mode === 'idf') btnIdf.classList.add('active');
    else if (mode === 'france') btnFrance.classList.add('active');
    
    if (mode !== 'anim') {
      clearInterval(autoplayInterval);
      if (viewport) viewport.className = 'map-viewport show-' + mode;
      if (statusText) statusText.textContent = mode === 'idf' ? 'Couverture Île-de-France' : 'Couverture Nationale (Toute la France)';
    } else {
      startAutoplay();
    }
  }
  
  function startAutoplay() {
    clearInterval(autoplayInterval);
    autoplayStep = 0;
    runAutoplayCycle();
    autoplayInterval = setInterval(runAutoplayCycle, 3500);
  }
  
  function runAutoplayCycle() {
    if (!viewport || !statusText) return;
    
    if (autoplayStep === 0) {
      viewport.className = 'map-viewport show-hq';
      statusText.textContent = 'Siège social : Vauréal (Île-de-France)';
      autoplayStep = 1;
    } else if (autoplayStep === 1) {
      viewport.className = 'map-viewport show-idf';
      statusText.textContent = 'Étape 1 : Couverture complète de l\'Île-de-France';
      autoplayStep = 2;
    } else {
      viewport.className = 'map-viewport show-france';
      statusText.textContent = 'Étape 2 : Intervention sur toute la France (National)';
      autoplayStep = 0;
    }
  }
  
  // Écouteurs d'événements
  if (btnAnim) btnAnim.addEventListener('click', () => setMode('anim'));
  if (btnIdf) btnIdf.addEventListener('click', () => setMode('idf'));
  if (btnFrance) btnFrance.addEventListener('click', () => setMode('france'));
  
  // Démarrage initial
  setMode('anim');
</script>
