---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import SectionHeading from '../../components/SectionHeading.astro';

export function getStaticPaths() {
  return [
    { params: { city: 'vaureal' }, props: { 
      cityName: 'Vauréal', 
      zipCode: '95490',
      description: 'SAM\'S TRANSPORT, votre spécialiste du déménagement et du débarras basé à Vauréal (95490). Intervention locale, en Île-de-France et toute la France.'
    }},
    { params: { city: 'cergy' }, props: { 
      cityName: 'Cergy', 
      zipCode: '95000',
      description: 'Déménagement et transport d’objets lourds à Cergy. Une équipe réactive pour vos besoins en Île-de-France et toute la France.'
    }},
    { params: { city: 'pontoise' }, props: { 
      cityName: 'Pontoise', 
      zipCode: '95000',
      description: 'Services de débarras et nettoyage à Pontoise. Intervention soignée en Île-de-France et toute la France.'
    }},
  ];
}

const { cityName, zipCode, description } = Astro.props;
---

<Layout title={`Déménagement & Débarras à ${cityName} (${zipCode}) | SAM'S TRANSPORT`} description={description}>
  <Header />
  
  <main>
    <section class="page-header">
      <div class="container animate-fade">
        <SectionHeading title={`Services à ${cityName}`} centered={true} light={true} />
        <p class="intro-text">{description}</p>
      </div>
    </section>

    <section class="location-detail section-padding">
      <div class="container">
        <div class="content-wrapper glass">
          <h3>Votre partenaire logistique à {cityName}</h3>
          <p>Basés localement à Vauréal, nous intervenons à <strong>{cityName}</strong> et dans toute l'Île-de-France pour tous vos besoins de transport, déménagement, débarras et nettoyage. Nous couvrons également les trajets longues distances vers toute la France.</p>
          
          <div class="local-benefits">
            <h4>Pourquoi nous choisir à {cityName} ?</h4>
            <ul>
              <li><strong>Flexibilité géographique :</strong> Interventions locales régulières et capacité de transport national longue distance.</li>
              <li><strong>Connaissance du terrain :</strong> Maîtrise des accès et des contraintes locales.</li>
              <li><strong>Sérieux & Professionnalisme :</strong> Une équipe qualifiée pour prendre soin de vos biens.</li>
            </ul>
          </div>
          
          <div class="actions">
            <a href="/devis" class="btn btn-primary btn-lg">Demander un devis pour {cityName}</a>
            <a href="/zones-intervention" class="btn btn-outline">Toutes nos zones d'intervention</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .page-header {
    background: var(--gradient-primary);
    color: var(--white);
    padding-top: 150px;
    padding-bottom: 80px;
  }
  
  .intro-text {
    font-size: 1.25rem;
    color: var(--text-light);
    max-width: 700px;
    margin: 1rem auto 0;
    text-align: center;
    line-height: 1.6;
  }
  
  .content-wrapper {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem;
    border-radius: 30px;
    box-shadow: var(--shadow-lg);
  }
  
  .content-wrapper h3 {
    margin-bottom: 1.5rem;
    font-size: 1.8rem;
  }
  
  .content-wrapper p {
    font-size: 1.1rem;
    line-height: 1.8;
    margin-bottom: 2rem;
  }
  
  .local-benefits {
    background: var(--bg-alt);
    padding: 2.5rem;
    border-radius: 20px;
    margin-bottom: 3rem;
  }
  
  .local-benefits h4 {
    margin-bottom: 1.5rem;
  }
  
  .local-benefits ul {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .local-benefits li {
    position: relative;
    padding-left: 1.5rem;
  }
  
  .local-benefits li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: bold;
  }
  
  .actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  
  @media (max-width: 768px) {
    .content-wrapper {
      padding: 2rem 1.5rem;
    }
  }
</style>
