---
interface Props {
  title: string;
  subtitle?: string;
  centered?: boolean;
  light?: boolean;
}

const { title, subtitle, centered = false, light = false } = Astro.props;
---

<div class={`section-heading ${centered ? 'centered' : ''} ${light ? 'light' : ''}`}>
  {subtitle && <span class="subtitle">{subtitle}</span>}
  <h2>{title}</h2>
  <div class="underline"></div>
</div>

<style>
  .section-heading {
    margin-bottom: 3.5rem;
  }
  
  .centered {
    text-align: center;
  }
  
  .centered .underline {
    margin: 1.5rem auto 0;
  }
  
  .subtitle {
    display: block;
    color: var(--accent);
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 2px;
    font-size: 0.85rem;
    margin-bottom: 0.5rem;
    font-family: 'Outfit', sans-serif;
  }
  
  h2 {
    font-size: 2.5rem;
    margin: 0;
  }
  
  .light h2 {
    color: var(--white);
  }
  
  .underline {
    width: 60px;
    height: 4px;
    background: var(--gradient-accent);
    margin-top: 1.5rem;
    border-radius: 2px;
  }
</style>
